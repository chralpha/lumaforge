{
  "name": "lumaforge",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@10.18.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/chralpha/lumaforge"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "worktree": "bash scripts/worktree.sh",
    "format": "prettier --write \"src/**/*.ts\" ",
    "lint": "eslint --fix",
    "prepare": "simple-git-hooks",
    "serve": "vite preview",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@headlessui/react": "2.2.10",
    "@lumaforge/luma-jpeg-runtime": "workspace:*",
    "@lumaforge/luma-raw-runtime": "workspace:*",
    "@pastel-palette/tailwindcss": "1.0.0-canary.3",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tooltip": "1.2.8",
    "@remixicon/react": "4.9.0",
    "@tanstack/react-query": "5.99.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "es-toolkit": "1.46.0",
    "foxact": "0.3.0",
    "immer": "11.1.4",
    "jotai": "2.19.1",
    "lucide-react": "1.8.0",
    "motion": "12.38.0",
    "ofetch": "1.5.1",
    "radix-ui": "1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router": "7.14.2",
    "react-scan": "0.5.3",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "usehooks-ts": "3.1.1"
  },
  "devDependencies": {
    "@egoist/tailwindcss-icons": "1.9.2",
    "@iconify-json/mingcute": "1.2.7",
    "@innei/prettier": "^1.0.0",
    "@tailwindcss/container-queries": "0.1.1",
    "@tailwindcss/postcss": "4.2.4",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "10.5.0",
    "code-inspector-plugin": "1.5.1",
    "eslint": "10.2.1",
    "eslint-config-hyoban": "7.0.3",
    "jsdom": "^26.1.0",
    "lint-staged": "16.4.0",
    "postcss": "8.5.10",
    "postcss-import": "16.1.1",
    "prettier": "3.8.3",
    "simple-git-hooks": "2.13.1",
    "tailwind-scrollbar": "4.0.2",
    "tailwind-variants": "3.2.2",
    "tailwindcss": "4.2.4",
    "tailwindcss-animate": "1.0.7",
    "tailwindcss-safe-area": "1.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.9",
    "vite-plugin-checker": "0.13.0",
    "vite-plugin-route-builder": "0.4.1",
    "vitest": "^3.2.4"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --ignore-path ./.gitignore --write "
    ],
    "*.{js,ts,cjs,mjs,jsx,tsx,json}": [
      "eslint --fix"
    ]
  }
}
