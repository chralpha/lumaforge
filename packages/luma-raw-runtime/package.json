{
  "name": "@lumaforge/luma-raw-runtime",
  "type": "module",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Performance-first browser RAW runtime for LumaForge.",
  "license": "SEE LICENSE IN LICENSE",
  "sideEffects": [
    "./dist/*.wasm",
    "./dist/*.worker.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/src/runtime-node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "THIRD_PARTY_LICENSES",
    "THIRD_PARTY_NOTICES.md",
    "dist",
    "native/build-libraw.sh",
    "native/emcc-flags.sh",
    "native/libraw_wrapper.cpp",
    "native/patches/README.md",
    "native/scripts",
    "native/sources.lock.json"
  ],
  "scripts": {
    "build": "vite build --config vite.config.ts && tsc -p tsconfig.build.json",
    "build:native": "LUMA_RAW_MEMORY_PROFILE=desktop bash native/build-libraw.sh && LUMA_RAW_MEMORY_PROFILE=low-memory bash native/build-libraw.sh",
    "build:native:desktop": "LUMA_RAW_MEMORY_PROFILE=desktop bash native/build-libraw.sh",
    "build:native:low-memory": "LUMA_RAW_MEMORY_PROFILE=low-memory bash native/build-libraw.sh",
    "fixtures:diagnose-mobile-raw": "node fixtures/scripts/diagnose-raw-compatibility.mjs --all",
    "fixtures:diagnose-mobile-raw:ci": "node fixtures/scripts/diagnose-raw-compatibility.mjs --purpose=ci-smoke",
    "fixtures:fetch-public": "node fixtures/scripts/fetch-public-fixtures.mjs --purpose=ci-smoke",
    "fixtures:fetch-public:all": "node fixtures/scripts/fetch-public-fixtures.mjs --all",
    "native:fetch": "node native/scripts/fetch-sources.mjs",
    "native:verify": "node native/scripts/verify-native-artifacts.mjs && pnpm --filter @lumaforge/luma-raw-runtime native:verify-baseline",
    "native:verify-baseline": "node native/scripts/verify-no-baseline-deps.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src worker fixtures/scripts --exclude src/native-smoke.test.ts",
    "test:native-smoke": "vitest run src/native-smoke.test.ts --environment jsdom",
    "bench:serve": "vite --host 0.0.0.0 --port 4174 --config vite.config.ts"
  },
  "dependencies": {
    "@lumaforge/luma-native-artifacts": "workspace:*"
  }
}
