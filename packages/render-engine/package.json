{
  "name": "@lumaforge/render-engine",
  "type": "module",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Headless render engine for LumaForge — composes luma-color, luma-raw, and luma-jpeg runtimes. Runs in browser and Node.js.",
  "license": "SEE LICENSE IN LICENSE",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/src/manifest/index.d.ts",
      "import": "./dist/manifest.js"
    },
    "./policy": {
      "types": "./dist/src/policy/index.d.ts",
      "import": "./dist/policy.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "vite build --config vite.config.ts && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src"
  },
  "dependencies": {
    "@lumaforge/luma-color-runtime": "workspace:*",
    "@lumaforge/luma-jpeg-runtime": "workspace:*",
    "@lumaforge/luma-raw-runtime": "workspace:*"
  }
}
